{
  "skipDangerousModePermissionPrompt": true,
  "hasCompletedOnboarding": true,
  "theme": "dark",
  "editorMode": "normal",
  "feedbackSurveyRate": 0,
  "awaySummaryEnabled": false,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "AskUserQuestion",
      "TodoWrite",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop"
    ]
  },
  "enableAllProjectMcpServers": false,
  "enabledPlugins": {
    "beads@beads-marketplace": false,
    "AIPowerUserCapabilities-agent-engineering@aim": false,
    "AIPowerUserCapabilities-autonomous-coding@aim": false,
    "AIPowerUserCapabilities-cloudwatch-migration@aim": false,
    "AIPowerUserCapabilities-code-review@aim": false,
    "AIPowerUserCapabilities-comms@aim": false,
    "AIPowerUserCapabilities-core-dev@aim": true,
    "AIPowerUserCapabilities-multiagent@aim": false,
    "AIPowerUserCapabilities-pipeline-ops@aim": false,
    "AIPowerUserCapabilities-project-mgmt@aim": false,
    "AIPowerUserCapabilities-research@aim": false,
    "AIPowerUserCapabilities-threat-modeler@aim": false,
    "AIPowerUserCapabilities-writing@aim": false,
    "AmazonBuilderCoreAIAgents-pipeline-assistant@aim": false,
    "AtlasAICapabilities-all@aim": false,
    "MeshClawAICapabilities-all@aim": false,
    "StoreGenAiCapabilities-all@aim": false,
    "ScheduledCoverageBooster-all@aim": false,
    "TalonAiCapabilities-talon-dev@aim": false,
    "AmazonBuilderCoreAIAgents-core@aim": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash(git checkout -b*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash(git switch -c*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard pr-workflow"
          }
        ]
      },
      {
        "matcher": "Bash(sudo *)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      },
      {
        "matcher": "Bash(apt install*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      },
      {
        "matcher": "Bash(apt-get install*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      },
      {
        "matcher": "Bash(dnf install*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      },
      {
        "matcher": "Bash(yum install*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      },
      {
        "matcher": "Bash(pacman -S*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      },
      {
        "matcher": "Bash(brew install*)",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} tap guard dangerous-command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} prime --hook"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} prime --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "case \"${GT_ROLE:-}\" in *witness*|*refinery*|deacon*|*boot*) exit 0 ;; *) {{GT_BIN}} mail check --inject ;; esac"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} costs record &"
          }
        ]
      }
    ]
  }
}
